{
  "name": "backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "src",
  "prefix": "incap",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/backend"],
      "options": {
        "cwd": "apps/backend",
        "commands": [
          "npm run build"
        ],
        "parallel": false
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/backend",
        "commands": [
          "node dist/server.js"
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/backend", "{workspaceRoot}/apps/backend/tests-results"],
      "options": {
        "cwd": "apps/backend",
        "commands": [
          "npm run test"
        ],
        "parallel": false
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/backend", "{workspaceRoot}/apps/backend/tests-results"],
      "options": {
        "cwd": "apps/backend",
        "commands": [
          "npm run coverage"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/backend",
        "commands": [
          "npm run lint"
        ],
        "parallel": false
      }
    }
  },
  "tags": ["type:app", "scope:backend"]
}
